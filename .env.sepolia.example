# ── Backend Configuration (Go) ──────────────────────────────────────────────

# HTTP Server Port
PORT=8080

# CORS: comma-separated list of origins allowed to call the Go backend directly.
# In local dev, the Next.js proxy (localhost:3000) is the only caller.
# In production, set to your deployed frontend domain.
# ALLOWED_ORIGINS="http://localhost:3000"

# (Optional) Event streaming and caching infra.
# If these are missing, the server falls back to running without them.
# KAFKA_BROKERS="localhost:9092"
# REDIS_URL="redis://localhost:6379"

# Firebase Auth: Project ID used for token validation (issuer + audience check).
# Found in Firebase Console -> Project Settings -> General.
FIREBASE_PROJECT_ID="your-firebase-project-id"

# Gemini API key — powers every specialized agent in the orchestrator.
# Get one at https://aistudio.google.com/app/apikey.
# If unset, the orchestrator still runs but agents return deterministic stubs.
GEMINI_API_KEY="your-gemini-api-key"
# GEMINI_MODEL="gemini-2.0-flash"

# RAG retrieval. This project uses Weaviate for the vector store role shown as
# Pinecone in the n8n workbook.
WEAVIATE_URL="localhost:8081"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# ── Frontend Configuration (Next.js) ────────────────────────────────────────

# Go backend origin — used by next.config.ts rewrites() to proxy /api/* and /auth/*.
# Local dev: leave as-is (matches default PORT above).
# Production: set to your deployed Go backend URL (e.g. https://api.yourdomain.com).
NEXT_PUBLIC_API_URL="http://localhost:8080"

# Firebase Config — found in Firebase Console -> Project Settings -> General -> Your apps.
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-firebase-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
