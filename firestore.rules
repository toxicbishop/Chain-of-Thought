rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // User Rules - Users can only read/write their own profiles and chats
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /chats/{chatId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Collaborative Room Rules - Members only
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      // Only authenticated users can create rooms or edit them
      allow write: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
      match /presence/{userId} {
        // Users can only write their own presence status
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
  }
}
